# Example environment variables for my_backend
# Copy this file to `.env` locally and fill in real values. NEVER commit real secrets.

# App
PORT=3000

# Database (Postgres / Supabase)
DATABASE_URL=

# Supabase storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth2
GOOGLE_CLIENT_ID=

# Google Mail OAuth2
GOOGLE_MAIL_CLIENT_ID=
GOOGLE_MAIL_CLIENT_SECRET=
GOOGLE_MAIL_REFRESH_TOKEN=
# Cấu hình App
PORT=3000

# Cấu hình Database (PostgreSQL từ Supabase)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Cấu hình Supabase (dành cho Upload Storage)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=your_supabase_key

# Cấu hình JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
